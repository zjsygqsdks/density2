# server.env.example — Copy to server.env and fill in your values.
# server.env is listed in .gitignore so credentials are never committed.

# ── Required ─────────────────────────────────────────────────────────────────
REMOTE_HOST=192.168.1.100       # server IP or hostname
REMOTE_PORT=22                  # SSH port
REMOTE_USER=ubuntu              # SSH username
REMOTE_DIR=/home/ubuntu/density2 # absolute path on server

# ── Optional ─────────────────────────────────────────────────────────────────
# SSH_KEY=~/.ssh/id_rsa         # SSH private key (default: ~/.ssh/id_rsa)
# DATA_DIR=data                 # local data dir to upload (default: data)
# REMOTE_VENV=${REMOTE_DIR}/.venv  # Python venv on server

# ── Conda (alternative to venv) ───────────────────────────────────────────────
# CONDA_ENV=dustnerf             # conda environment name (overrides venv)
